---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>TechFrontier Intelligence</h1>
			<p style="margin-bottom: 3rem; font-size: 1.15rem; color: var(--text-secondary);">A curated daily brief tracking architectural shifts, open-source innovation, and early-stage commercial viability for founders and engineers.</p>
			
			<section>
				<h2>Latest Briefs</h2>
				<ul class="post-list">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`} class="post-card">
									<h4>{post.data.title}</h4>
									<p>
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
